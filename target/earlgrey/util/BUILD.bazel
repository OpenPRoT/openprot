load("@rules_rust//rust:defs.bzl", "rust_library", "rust_test")
load("//target/earlgrey:defs.bzl", "TARGET_COMPATIBLE_WITH")

rust_library(
    name = "util",
    srcs = [
        "boot_log.rs",
        "boot_svc.rs",
        "clock.rs",
        "device_id.rs",
        "error.rs",
        "flash.rs",
        "lib.rs",
        "manifest.rs",
        "misc.rs",
        "mubi.rs",
        "perso_tlv.rs",
        "ret_ram.rs",
        "rom_error.rs",
        "tags.rs",
        "timer.rs",
    ],
    crate_name = "earlgrey_util",
    edition = "2024",
    visibility = ["//visibility:public"],
    deps = [
        "//hal/blocking/flash:driver",
        "//target/earlgrey/registers:rv_timer",
        "//target/earlgrey/registers:top_earlgrey",
        "//util/error",
        "//util/types",
        "@pigweed//pw_log/rust:pw_log",
        "@pigweed//pw_status/rust:pw_status",
        "@rust_crates//:zerocopy",
        "@zfmt//zfmt",
    ],
)

rust_test(
    name = "util_test",
    crate = ":util",
)

rust_library(
    name = "dfu",
    srcs = ["dfu.rs"],
    crate_name = "earlgrey_dfu",
    edition = "2024",
    target_compatible_with = TARGET_COMPATIBLE_WITH,
    visibility = ["//visibility:public"],
    deps = [
        ":util",
        "//hal/blocking/flash",
        "//hal/blocking/usb:hal_usb",
        "//protocol/usb/dfu",
        "//services/flash:client",
        "//target/earlgrey/services/sysmgr:client",
        "//util/error",
        "//util/ipc",
        "//util/zfmt",
        "@pigweed//pw_log/rust:pw_log",
        "@pigweed//pw_status/rust:pw_status",
        "@rust_crates//:zerocopy",
        "@zfmt//zfmt",
    ],
)
